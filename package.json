{
  "name": "night-festival",
  "version": "1.0.0",
  "description": "四八七十二·北魏夜游生活节活动平台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "npx tsx watch api/src/index.ts",
    "build": "npm run build:client",
    "build:client": "vite build",
    "build:server": "npx tsc -p api/tsconfig.json",
    "preview": "vite preview",
    "start": "node api/dist/index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "lint": "npx eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.378.0",
    "framer-motion": "^11.1.9",
    "qrcode.react": "^3.1.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.12.12",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.11",
    "typescript": "^5.4.5",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "tsx": "^4.10.5",
    "prisma": "^5.14.0",
    "@prisma/client": "^5.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7"
  }
}
